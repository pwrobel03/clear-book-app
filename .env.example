# ─────────────────────────────────────────────────────────────────────────────
# ClearBook — environment variables template
# Copy this file to .env and fill in the values.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
DB_NAME=clearbook
DB_USER=clearbook_user
DB_PASSWORD=change_me_strong_password

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=change_me_64_hex_characters_minimum

# Optional — defaults shown
JWT_ACCESS_EXPIRATION_MS=900000
JWT_REFRESH_EXPIRATION_DAYS=7

# ── E-mail (Gmail SMTP) ───────────────────────────────────────────────────────
# Use a Gmail App Password (not your main account password).
# Generate at: https://myaccount.google.com/apppasswords
EMAIL_USERNAME=your_gmail@gmail.com
EMAIL_2FA_PASSWORD=your_gmail_app_password

# ── Frontend ──────────────────────────────────────────────────────────────────
# Public URL of the frontend — used by the backend for CORS and e-mail links.
# Local development:
FRONTEND_URL=http://localhost:3000
# Production example:
# FRONTEND_URL=https://clearbook.yourdomain.com
